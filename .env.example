# ─── LiteMaas / LiteLLM ────────────────────────────────────
# Master key used by the bot to authenticate with LiteMaas
LITEMAAS_URL=http://litellm-service:4000
LITELLM_MASTER_KEY=sk-..............
LITEMAAS_POSTGRES_DB=litemaas
LITEMAAS_POSTGRES_USER=litemaas
LITEMAAS_POSTGRES_PASSWORD=changeme


# Your real OpenAI API key (used by LiteMaas to call OpenAI)
OPENAI_API_KEY=sk-openai-your-key-here

# ─── Telegram ──────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=..........

# ─── Bot settings ──────────────────────────────────────────
# Model to use via LiteMaas (must match a model_name in litemaas/config.yaml)
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO

BOT_POSTGRES_DB=bot_db
BOT_POSTGRES_USER=bot
BOT_POSTGRES_PASSWORD=changeme


# ─── Frontend (Next.js) ─────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=changeme_nextauth_secret_at_least_32_chars
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=changeme_admin_password